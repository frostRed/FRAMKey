{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "trusted-wallet-ui",
  "description": "Trusted FRAMKey wallet UI capability for local app status and read-only account requests.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-framkey-provider-request",
    "allow-framkey-review-queue",
    "allow-framkey-transaction-activity",
    "allow-framkey-recovery-state",
    "allow-framkey-clear-recovery-state",
    "allow-framkey-decide-review-request",
    "allow-framkey-dismiss-review-request",
    "allow-framkey-clear-review-queue",
    "allow-framkey-account-permissions",
    "allow-framkey-revoke-account-permission",
    "allow-framkey-provider-events",
    "allow-framkey-clear-provider-events",
    "allow-framkey-run-dapp-compatibility-check",
    "allow-framkey-dapp-session",
    "allow-framkey-navigate-dapp",
    "allow-framkey-smoke-event",
    "allow-framkey-status",
    "allow-framkey-rpc-health",
    "allow-framkey-authorize-keychain-helper",
    "allow-framkey-wallet-assets",
    "allow-framkey-send-native-transfer",
    "allow-framkey-send-token-transfer",
    "allow-framkey-switch-session-chain",
    "allow-framkey-recovery-smoke-pack",
    "allow-framkey-create-keychain-vault",
    "allow-framkey-validate-recovery-set",
    "allow-framkey-recover-keychain-vault",
    "allow-framkey-pick-vault-backup-file",
    "allow-framkey-pick-recovery-files",
    "allow-framkey-pick-recovery-out-dir",
    "allow-framkey-reveal-path",
    "allow-open-dapp-webview"
  ]
}
