{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FRAMKey",
  "version": "0.1.0",
  "identifier": "dev.framkey.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "./scripts/prepare-tauri-sidecars.sh",
      "cwd": "../../..",
      "wait": true
    },
    "beforeBuildCommand": {
      "script": "./scripts/prepare-tauri-sidecars.sh",
      "cwd": "../../.."
    },
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FRAMKey",
        "url": "index.html",
        "width": 1160,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/framkey-signer-helper", "binaries/framkey-ch347-helper"]
  }
}
